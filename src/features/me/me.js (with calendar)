// ─── Google Calendar service ──────────────────────────────
//
// SETUP REQUIRED:
// 1. Go to https://console.cloud.google.com
// 2. Create a new project (or use an existing one)
// 3. Enable the "Google Calendar API"
// 4. Create OAuth 2.0 credentials (type: Web application)
// 5. Add your domain (https://your-username.github.io) to authorised JS origins
// 6. Add your domain + /calendar-callback to authorised redirect URIs
// 7. Paste your Client ID into CLIENT_ID below
//
// Until that's done, the calendar will run in DEMO mode showing example events.

const CLIENT_ID = 'YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com';
const SCOPES    = 'https://www.googleapis.com/auth/calendar.readonly';
const DISCOVERY = 'https://www.googleapis.com/discovery/v1/apis/calendar/v3/rest';

let tokenClient = null;
let gapiReady   = false;
let gisReady    = false;

// ─── Initialisation ───────────────────────────────────────
export async function initCalendar() {
  if (CLIENT_ID.startsWith('YOUR_GOOGLE')) {
    console.info('[Bowline Calendar] Running in DEMO mode. See src/services/calendar.js for setup instructions.');
    return { demo: true };
  }

  await Promise.all([loadGapi(), loadGis()]);

  await new Promise((resolve) => {
    gapi.load('client', async () => {
      await gapi.client.init({ discoveryDocs: [DISCOVERY] });
      gapiReady = true;
      resolve();
    });
  });

  tokenClient = google.accounts.oauth2.initTokenClient({
    client_id: CLIENT_ID,
    scope: SCOPES,
    callback: () => {},
  });
  gisReady = true;
  return { demo: false };
}

function loadGapi() {
  return new Promise((resolve, reject) => {
    if (window.gapi) return resolve();
    const s = document.createElement('script');
    s.src = 'https://apis.google.com/js/api.js';
    s.onload  = resolve;
    s.onerror = reject;
    document.head.appendChild(s);
  });
}

function loadGis() {
  return new Promise((resolve, reject) => {
    if (window.google?.accounts) return resolve();
    const s = document.createElement('script');
    s.src = 'https://accounts.google.com/gsi/client';
    s.onload  = resolve;
    s.onerror = reject;
    document.head.appendChild(s);
  });
}

// ─── Sign-in / sign-out ───────────────────────────────────
export function isSignedIn() {
  if (CLIENT_ID.startsWith('YOUR_GOOGLE')) return false;
  return gapi?.client?.getToken() !== null && gapi?.client?.getToken() !== undefined;
}

export async function signIn() {
  if (!tokenClient) await initCalendar();
  return new Promise((resolve, reject) => {
    tokenClient.callback = (resp) => {
      if (resp.error) reject(resp);
      else resolve(resp);
    };
    tokenClient.requestAccessToken({ prompt: 'consent' });
  });
}

export function signOut() {
  const token = gapi?.client?.getToken();
  if (token) {
    google.accounts.oauth2.revoke(token.access_token);
    gapi.client.setToken(null);
  }
}

// ─── Fetch events ─────────────────────────────────────────
export async function fetchTodayEvents() {
  if (CLIENT_ID.startsWith('YOUR_GOOGLE')) return demoEvents();

  const now      = new Date();
  const midnight = new Date(); midnight.setHours(23, 59, 59);

  try {
    const resp = await gapi.client.calendar.events.list({
      calendarId:   'primary',
      timeMin:      now.toISOString(),
      timeMax:      midnight.toISOString(),
      singleEvents: true,
      orderBy:      'startTime',
      maxResults:   20,
    });
    return resp.result.items.map(parseEvent);
  } catch (e) {
    console.error('[Bowline Calendar] fetch failed:', e);
    return [];
  }
}

export async function fetchUpcomingEvents(days = 7) {
  if (CLIENT_ID.startsWith('YOUR_GOOGLE')) return demoEvents(days);

  const now = new Date();
  const end = new Date(); end.setDate(end.getDate() + days);

  try {
    const resp = await gapi.client.calendar.events.list({
      calendarId:   'primary',
      timeMin:      now.toISOString(),
      timeMax:      end.toISOString(),
      singleEvents: true,
      orderBy:      'startTime',
      maxResults:   50,
    });
    return resp.result.items.map(parseEvent);
  } catch (e) {
    console.error('[Bowline Calendar] fetch failed:', e);
    return [];
  }
}

// ─── Parse a Google event into Bowline format ─────────────
function parseEvent(ev) {
  const start = ev.start.dateTime || ev.start.date;
  const end   = ev.end.dateTime   || ev.end.date;
  const allDay = !ev.start.dateTime;

  return {
    id:          ev.id,
    title:       ev.summary || '(no title)',
    location:    ev.location || null,
    description: ev.description || null,
    start, end, allDay,
    startDate:   new Date(start),
    endDate:     new Date(end),
    attendees:   ev.attendees?.length || 0,
    // Bowline-specific enrichment
    type:        classifyEvent(ev),
    needsPrep:   needsPreparation(ev),
    leaveTime:   estimateLeaveTime(ev),
  };
}

// ─── Bowline event classification ─────────────────────────
// Looks at the title + location to suggest which Bowline routine fits.
function classifyEvent(ev) {
  const t = (ev.summary || '').toLowerCase();
  const l = (ev.location || '').toLowerCase();

  if (/dentist|doctor|gp|hospital|appointment|consultation|therapy|appt/.test(t)) return 'medical';
  if (/interview|review|1[\s-:]?1|one[\s-]?to[\s-]?one|appraisal/.test(t))        return 'high-stakes';
  if (/social|lunch|dinner|drinks|coffee|party|wedding|birthday/.test(t))         return 'social';
  if (/standup|meeting|sync|call|catch[\s-]?up|presentation/.test(t))             return 'work-meeting';
  if (/focus|deep[\s-]?work|writing/.test(t))                                     return 'focus';
  if (/travel|flight|train|drive/.test(t))                                        return 'travel';
  if (ev.location && !l.includes('zoom') && !l.includes('teams') && !l.includes('meet')) return 'in-person';
  return 'general';
}

function needsPreparation(ev) {
  const c = classifyEvent(ev);
  return ['medical', 'high-stakes', 'in-person', 'travel'].includes(c);
}

function estimateLeaveTime(ev) {
  if (!ev.location || !ev.start.dateTime) return null;
  const l = ev.location.toLowerCase();
  if (l.includes('zoom') || l.includes('teams') || l.includes('meet')) return null;
  const start = new Date(ev.start.dateTime);
  // Default: 30 min buffer for in-person
  const leave = new Date(start.getTime() - 30 * 60 * 1000);
  return leave;
}

// ─── Demo events (when not connected to real Google) ──────
function demoEvents(days = 1) {
  const today = new Date();
  const set = (h, m, label, location, descriptor) => {
    const d = new Date(today); d.setHours(h, m, 0, 0);
    return {
      id: `demo-${h}${m}`, title: label, location,
      start: d.toISOString(), end: new Date(d.getTime() + 60 * 60 * 1000).toISOString(),
      allDay: false, startDate: d, endDate: new Date(d.getTime() + 60 * 60 * 1000),
      attendees: 0, type: descriptor, needsPrep: ['medical', 'in-person', 'high-stakes'].includes(descriptor),
      leaveTime: location ? new Date(d.getTime() - 30 * 60 * 1000) : null,
      isDemo: true,
    };
  };
  return [
    set(15, 0,  'GP appointment',         'NHS Healthcare Centre',     'medical'),
    set(17, 30, 'Coffee with Alex',       'Tate Modern café',          'social'),
    set(19, 0,  'Evening walk',           null,                         'general'),
  ].filter(e => e.startDate > today).slice(0, days * 3);
}

// ─── Generate a prep checklist for an event ──────────────
export function getPrepChecklist(event) {
  const base = {
    medical: [
      'Confirm the appointment time and address',
      'Bring ID and any relevant documents',
      'Write down questions you want to ask',
      'Leave 30 minutes early in case of delays',
      'Have headphones in case of waiting room overwhelm',
      'Plan recovery time afterwards',
    ],
    'high-stakes': [
      'Re-read the agenda or brief',
      'Prepare any documents you need to show',
      'Test your tech 5 minutes before if remote',
      'Have water and a fidget within reach',
      'Plan recovery time afterwards',
    ],
    'in-person': [
      'Check the route and travel time',
      'Wallet, keys, phone, headphones, ID',
      'Bring sensory items if needed',
      'Leave on time — buffer is your friend',
    ],
    social: [
      'Confirm time and location',
      'Have an exit plan if you need one',
      'Eat beforehand if you find it hard during',
      'Plan recovery time after',
    ],
    'work-meeting': [
      'Skim the agenda if there is one',
      'Have water within reach',
      'Mute notifications during',
    ],
    travel: [
      'Tickets, ID, charged devices',
      'Snacks and water',
      'Headphones for sensory protection',
      'Buffer time built in',
    ],
    focus: [
      'Headphones on, notifications off',
      'Water and snack within reach',
      'One task only — not three',
    ],
    general: [
      'No major prep needed',
    ],
  };
  return base[event.type] || base.general;
}
